# ── Database ──────────────────────────────────────
DB_ENGINE=sqlite                          # sqlite | postgres
SQLITE_PATH=data/ai_updates.db            # relative to project root
# POSTGRES_DSN=postgresql://user:pass@localhost:5432/ai_updates

# ── WhatsApp Direct (pywhatkit — no API needed!) ──
# This uses WhatsApp Web on your machine. Just put your phone number.
# You must be logged into WhatsApp Web in Chrome on this machine.
WHATSAPP_DIRECT_ENABLED=true
WHATSAPP_DIRECT_PHONE=+919876543210      # your WhatsApp number with country code

# ── WhatsApp Cloud API (optional — skip if using Direct above) ──
# Only fill these if you have a Meta Business account with WhatsApp API access.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_RECIPIENT_WA_ID=
# WHATSAPP_API_URL=https://graph.facebook.com/v18.0

# ── Email Fallback (SMTP) ────────────────────────
# Used automatically when WhatsApp fails.
# For Gmail: use an App Password, NOT your regular password.
# Create one at: https://myaccount.google.com/apppasswords
EMAIL_ENABLED=true
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=your-email@gmail.com         # your Gmail address
EMAIL_PASSWORD=your_app_password          # 16-char app password from Google
EMAIL_RECIPIENT=your-email@gmail.com      # where to receive the digest

# ── Scheduler ─────────────────────────────────────
INGESTION_INTERVAL_MINUTES=12
COMPILE_TIME_IST=05:55
SEND_TIME_IST=06:00

# ── GitHub (optional, raises rate limit) ──────────
GITHUB_TOKEN=

# ── NewsAPI.org (free tier: 100 requests/day) ─────
# Get your API key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ── Notification ──────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5
MAX_MESSAGE_CHARS=1200
